<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📳 微信自主摇一摇"
            android:textColor="#333"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="系统层传感器修改"
            android:textColor="#888"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="直接 Hook 加速度传感器数据，微信内所有摇一摇网页/原生功能都会生效"
            android:textColor="#999"
            android:textSize="12sp" />

        <!-- 启用开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#FFF"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:text="启用模块"
                android:textColor="#333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchEnable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 每秒次数 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="每秒增加次数"
            android:textColor="#333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#FFF"
            android:orientation="horizontal"
            android:padding="16dp">

            <SeekBar
                android:id="@+id/seekShakesPerSecond"
                style="@style/Widget.AppCompat.SeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:max="49"
                android:progress="29" />

            <TextView
                android:id="@+id/tvShakesPerSecond"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:text="10"
                android:textColor="#764ba2"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="范围: 1 ~ 50 次/秒"
            android:textColor="#aaa"
            android:textSize="12sp" />

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_save_bg"
            android:text="保存设置"
            android:textColor="#FFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 浮窗控制按钮 -->
        <Button
            android:id="@+id/btnShowFloating"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_save_bg"
            android:text="启动控制 (悬浮窗+通知栏)"
            android:textColor="#FFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Root 检测按钮 -->
        <Button
            android:id="@+id/btnCheckRoot"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_check_bg"
            android:text="检测 Root 权限"
            android:textColor="#FFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 使用说明 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="使用说明"
                android:textColor="#333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="1. 保存设置后，打开 LSPosed Manager\n2. 在模块列表中启用「微信自主摇一摇」\n3. 在作用域中勾选微信 (com.tencent.mm)\n4. 强制停止微信后重新打开\n5. 微信扫码打开任意摇一摇网页\n6. 点击「开始挑战」即可自动计数"
                android:textColor="#666"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 版本号 -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="v1.1"
            android:textColor="#BBB"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
